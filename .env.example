# --- LangSmith (required for Modules 3 and 4, recommended everywhere) ---
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_PROJECT="modular-workshops"

# Required for Module 03 §1 (LangSmith Gateway). Set to the same value as LANGSMITH_API_KEY.
LANGSMITH_API_KEY_GATEWAY="<langsmith-api-key>"

# Workspace ID for gateway policies (Module 03 §1.1). Find in LangSmith Settings → Workspace.
WORKSPACE_ID="<workspace-id>"

# --- Model providers (set whichever your workshop uses) ---
OPENAI_API_KEY="<openai-api-key>"
# ANTHROPIC_API_KEY="<anthropic-api-key>"

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
# AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
# AZURE_OPENAI_API_VERSION=""

# AWS Bedrock (optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION_NAME=""
# AWS_MODEL_ARN=""

# --- Tools used by Module 1 (LangGraph), Module 2 (Deep Agents),  Module 3 (Deploy), and Module 5 (Engine) ---
TAVILY_API_KEY="<tavily-api-key>"
