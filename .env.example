# --- Workspace specific to the user --- #
# REQUIRED. A unique per-attendee slug (e.g. "jane-doe"). It scopes every named
# resource you create so concurrent attendees don't overwrite each other:
# the LangSmith tracing project, eval datasets, the engine-demo assistant, its
# Context Hub repo, and annotation queues. Modules fail loudly if this is unset
# or still the placeholder below.
WORKSHOP_USER="<first-last>"
# --- LangSmith (required for Modules 3 and 4, recommended everywhere) ---
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="<langsmith-api-key>"

LANGSMITH_PROJECT="trading-agent-workshop-${WORKSHOP_USER}"

# --- Model providers ---
## This KEY SHOULD BE THE SAME AS YOUR TRUEFOUNDRY API KEY
OPENAI_API_KEY="<openai-api-key>"

# --- TrueFoundry LLM Gateway (set if desired to test with the workshop) ---
TRUEFOUNDRY_API_KEY_GATEWAY="<truefoundry-api-key>"

WORKSPACE_ID="<workspace-id>"

# Required for Module 03 §1 (LangSmith Gateway). Set to the same value as LANGSMITH_API_KEY.
# LANGSMITH_API_KEY_GATEWAY="<langsmith-api-key>"

# Workspace ID for gateway policies (Module 03 §1.1). Find in LangSmith Settings → Workspace.

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
# AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
# AZURE_OPENAI_API_VERSION=""

# AWS Bedrock (optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION_NAME=""
# AWS_MODEL_ARN=""

# --- Tools used by Module 1 (LangGraph), Module 2 (Deep Agents),  Module 3 (Deploy), and Module 5 (Engine) ---
TAVILY_API_KEY="<tavily-api-key>"
